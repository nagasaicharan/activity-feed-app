{
  "expo": {
    "name": "ActivityFeedApp",
    "slug": "activity-feed-app",
    "scheme": "activityfeedapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "ios": {
      "bundleIdentifier": "com.activityfeedapp",
      "supportsTablet": true
    },
    "android": {
      "package": "com.activityfeedapp"
    },
    "web": {
      "bundler": "metro"
    }
  }
}
